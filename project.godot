; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Ethereia"
config/description="《仙冥大陆》2D 单机修仙 RPG - 第一部分《凡骨入道篇》"
config/version="0.0.1"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoload/GameState.gd"
EventBus="*res://scripts/autoload/EventBus.gd"
DataManager="*res://scripts/autoload/DataManager.gd"
InventorySystem="*res://scripts/autoload/InventorySystem.gd"
QuestManager="*res://scripts/autoload/QuestManager.gd"
KarmaManager="*res://scripts/autoload/KarmaManager.gd"
RelationshipManager="*res://scripts/autoload/RelationshipManager.gd"
DialogueManager="*res://scripts/systems/DialogueManager.gd"
SceneLoader="*res://scripts/autoload/SceneLoader.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/title="仙冥大陆 Ethereia"

